# Copy this file to .env.production on the production VM and fill real values.
# Do not commit .env.production to source control.

POSTGRES_PASSWORD=replace-with-strong-db-password
BACKEND_API_IMAGE=ghcr.io/polyphony-org/polyphony/backend-api:latest
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_URL=wss://your-livekit-domain
