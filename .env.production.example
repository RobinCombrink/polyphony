# Copy this file to .env.production on the production VM and fill real values.
# Do not commit .env.production to source control.

# Runtime mode and bind address
BACKEND_API_RUNTIME_ENV=production
BACKEND_API_BIND=0.0.0.0:5067

# Postgres runtime wiring
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=polyphony
POSTGRES_USERNAME=polyphony
POSTGRES_PASSWORD=replace-with-strong-db-password

# Backend image and auth
BACKEND_API_IMAGE=ghcr.io/polyphony-org/polyphony/backend-api:latest
BACKEND_API_CORS_ALLOWED_ORIGINS=https://app.polyphony.com
AUTH0_ISSUER=https://dev-polyphony.eu.auth0.com/
AUTH0_AUDIENCE=https://api.polyphony.com

# LiveKit runtime wiring
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_URL=wss://your-livekit-domain
